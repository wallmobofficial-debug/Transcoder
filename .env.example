# Required
BOT_TOKEN=your_telegram_bot_token
STORAGE_CHAT_ID=-100xxxxxxxxxx

# Optional — Telegram Bot API origin (self-hosted Bot API server to raise 50MB limit)
# TELEGRAM_API=https://api.telegram.org

# Database — local SQLite by default
# DATABASE_URL=sqlite:///./data/app.db
# For Turso:
# DATABASE_URL=libsql://wmreel-wallmob.aws-ap-south-1.turso.io
# TURSO_AUTH_TOKEN=your_turso_token

# Upload limits
# MAX_UPLOAD_SIZE_MB=500
# HLS_SEGMENT_DURATION=6

# Shared secret for reels-backend authentication
# TRANSCODER_SECRET=your_shared_secret

# Public URL for building callback URLs
# PUBLIC_URL=https://trascoder.onrender.com
